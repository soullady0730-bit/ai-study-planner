  <!-- Application logic JS -->
  <script>
    // State management
    let state = {
      subjects: [],
      dailyTime: 6,
      startTime: "09:00",
      includeBreaks: true,
      excludeMeals: "both",
      todaySchedule: [],
      theme: "dark"
    };

    // Date formatting helper
    function getTodayString() {
      const today = new Date();
      return today.toISOString().split('T')[0];
    }

    // Helper: calculate D-Day
    function calculateDDay(targetDateStr) {
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      
      const target = new Date(targetDateStr);
      target.setHours(0, 0, 0, 0);
      
      const diffTime = target - today;
      return Math.ceil(diffTime / (1000 * 60 * 60 * 24));
    }

    // LocalStorage loading/saving
    function saveState() {
      localStorage.setItem('ai_study_planner_state', JSON.stringify(state));
    }

    function loadState() {
      const stored = localStorage.getItem('ai_study_planner_state');
      if (stored) {
        try {
          state = JSON.parse(stored);
          document.getElementById('daily-study-time-input').value = state.dailyTime;
          document.getElementById('study-time-val').innerText = `${state.dailyTime}시간`;
          document.getElementById('start-time-input').value = state.startTime;
          document.getElementById('meal-exclusion-select').value = state.excludeMeals || "both";
          document.getElementById('break-toggle-input').checked = state.includeBreaks;
          
          if (state.theme) {
            document.documentElement.setAttribute('data-theme', state.theme);
            updateThemeToggleUI();
          }
        } catch (e) {
          console.error("LocalStorage parsing error. Resetting to mock data.");
          setupMockData();
        }
      } else {
        setupMockData();
      }
    }

    // Set relative mock data so it looks great on load
    function setupMockData() {
      const baseDate = new Date();
      
      const sub1 = new Date(baseDate);
      sub1.setDate(baseDate.getDate() + 3); // D-3
      
      const sub2 = new Date(baseDate);
      sub2.setDate(baseDate.getDate() + 5); // D-5
      
      const sub3 = new Date(baseDate);
      sub3.setDate(baseDate.getDate() + 7); // D-7

      state.subjects = [
        {
          id: 'mock-1',
          name: '정보사회론',
          examDate: sub1.toISOString().split('T')[0],
          importance: '상',
          expectedHours: 12,
          progress: 20
        },
        {
          id: 'mock-2',
          name: '현대시론',
          examDate: sub2.toISOString().split('T')[0],
          importance: '중',
          expectedHours: 8,
          progress: 45
        },
        {
          id: 'mock-3',
          name: '스페인어',
          examDate: sub3.toISOString().split('T')[0],
          importance: '하',
          expectedHours: 16,
          progress: 10
        }
      ];
      state.dailyTime = 6;
      state.startTime = "09:00";
      state.includeBreaks = true;
      state.excludeMeals = "both";
      state.theme = "dark";
      state.todaySchedule = [];
      saveState();
    }

    // Toast Notification helper
    function showToast(msg) {
      const toast = document.getElementById('toast-notify');
      document.getElementById('toast-message').innerText = msg;
      toast.classList.add('show');
      setTimeout(() => {
        toast.classList.remove('show');
      }, 2500);
    }

    // Theme toggle UI
    function updateThemeToggleUI() {
      const isLight = document.documentElement.getAttribute('data-theme') === 'light';
      document.getElementById('sun-icon').style.display = isLight ? 'none' : 'block';
      document.getElementById('moon-icon').style.display = isLight ? 'block' : 'none';
    }

    // Dashboard rendering
    function renderDashboard() {
      if (state.subjects.length === 0) {
        document.getElementById('dday-hero').innerHTML = '시험 정보 없음';
        document.getElementById('dday-sublist').innerHTML = '';
        document.getElementById('overall-percentage').innerText = '0%';
        document.getElementById('overall-stats').innerText = '등록된 과목 없음';
        document.getElementById('circle-progress-fill').style.strokeDashoffset = 283;
        return;
      }

      const subjectsWithDDay = state.subjects.map(s => {
        return { ...s, dDay: calculateDDay(s.examDate) };
      });

      const upcoming = subjectsWithDDay.filter(s => s.dDay >= 0);
      
      if (upcoming.length > 0) {
        upcoming.sort((a, b) => a.dDay - b.dDay);
        const closest = upcoming[0];
        let ddayStr = closest.dDay === 0 ? "D-Day" : `D-${closest.dDay}`;
        document.getElementById('dday-hero').innerHTML = `
          가장 가까운 시험: <br><span class="dday-main-highlight">${closest.name}</span> (${ddayStr})
        `;
      } else {
        document.getElementById('dday-hero').innerHTML = `진행 예정인 시험이 없습니다.`;
      }

      subjectsWithDDay.sort((a, b) => a.dDay - b.dDay);
      let sublistHTML = '';
      subjectsWithDDay.forEach(s => {
        let tagClass = 'tag-success';
        let dDayText = s.dDay > 0 ? `D-${s.dDay}` : (s.dDay === 0 ? 'D-Day' : '종료');
        
        if (s.dDay < 0) {
          tagClass = 'tag-success';
        } else if (s.dDay <= 2) {
          tagClass = 'tag-danger';
        } else if (s.dDay <= 5) {
          tagClass = 'tag-warning';
        } else {
          tagClass = 'tag-success';
        }
        
        sublistHTML += `
          <span class="dday-tag ${tagClass}">
            ${s.name} ${dDayText}
          </span>
        `;
      });
      document.getElementById('dday-sublist').innerHTML = sublistHTML;

      const totalProgress = state.subjects.reduce((sum, s) => sum + s.progress, 0);
      const avgProgress = Math.round(totalProgress / state.subjects.length);
      
      document.getElementById('overall-percentage').innerText = `${avgProgress}%`;
      document.getElementById('overall-stats').innerText = `${state.subjects.length}개 과목 전체 진도 상태`;
      
      const offset = 283 - (283 * avgProgress) / 100;
      document.getElementById('circle-progress-fill').style.strokeDashoffset = offset;
    }

    // Subjects list rendering
    function renderSubjects() {
      const container = document.getElementById('subjects-container');
      
      if (state.subjects.length === 0) {
        container.innerHTML = `
          <div class="empty-state">
            등록된 시험 과목이 없습니다. 위의 '+' 버튼을 눌러 과목을 추가해 보세요!
          </div>
        `;
        return;
      }

      let containerHTML = '';
      state.subjects.forEach(s => {
        const dDay = calculateDDay(s.examDate);
        
        let dDayScore = 0;
        if (dDay === 0) dDayScore = 100;
        else if (dDay > 0) dDayScore = Math.round(100 * Math.exp(-0.07 * dDay));

        let importanceScore = 30;
        if (s.importance === '상') importanceScore = 100;
        else if (s.importance === '중') importanceScore = 60;

        const hoursScore = Math.min(100, (s.expectedHours / 20) * 100);
        const incompleteScore = 100 - s.progress;

        const priorityScore = Math.round((dDayScore * 0.4) + (importanceScore * 0.3) + (hoursScore * 0.2) + (incompleteScore * 0.1));

        let badgeClass = 'tag-success';
        if (s.importance === '상') badgeClass = 'tag-danger';
        else if (s.importance === '중') badgeClass = 'tag-warning';

        let dDayText = dDay > 0 ? `D-${dDay}` : (dDay === 0 ? 'D-Day' : '종료');
        let dDayBadgeClass = dDay <= 2 && dDay >= 0 ? 'tag-danger' : 'tag-success';
        if (dDay < 0) dDayBadgeClass = 'tag-success';

        containerHTML += `
          <div class="subject-card">
            <div class="subject-card-top">
              <div class="subject-info">
                <h3>${s.name}</h3>
                <div class="subject-meta">
                  <span class="badge ${dDayBadgeClass}">${dDayText} (${s.examDate})</span>
                  <span class="badge ${badgeClass}">중요도: ${s.importance}</span>
                  <span class="badge priority-badge tooltip">
                    우선순위: ${priorityScore}점
                    <span class="tooltip-text">
                      <strong>우선순위 산출 근거:</strong><br>
                      - 시험임박도(40%): ${Math.round(dDayScore * 0.4)}점<br>
                      - 중요도(30%): ${Math.round(importanceScore * 0.3)}점<br>
                      - 공부량(20%): ${Math.round(hoursScore * 0.2)}점<br>
                      - 미진도율(10%): ${Math.round(incompleteScore * 0.1)}점
                    </span>
                  </span>
                </div>
              </div>
              <button class="btn btn-danger btn-icon" onclick="deleteSubject('${s.id}')" aria-label="삭제">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
              </button>
            </div>

            <div class="subject-progress-area">
              <div class="progress-bar-container">
                <div class="progress-bar-fill" style="width: ${s.progress}%"></div>
              </div>
              <div class="progress-label">
                <span>진도율</span>
                <span>${s.progress}% (목표 공부시간: ${s.expectedHours}시간)</span>
              </div>
              
              <div class="subject-slider-group">
                <input type="range" class="progress-slider" min="0" max="100" value="${s.progress}" 
                  oninput="updateSubjectProgressDirectly('${s.id}', this.value)" 
                  onchange="saveStateAndRefresh()">
              </div>
            </div>
          </div>
        `;
      });
      container.innerHTML = containerHTML;
    }

    // Add subject handler
    function addSubject() {
      const nameInput = document.getElementById('sub-name');
      const dateInput = document.getElementById('sub-date');
      const hoursInput = document.getElementById('sub-hours');
      const progressInput = document.getElementById('sub-progress');
      
      const name = nameInput.value.trim();
      const date = dateInput.value;
      const hours = parseInt(hoursInput.value);
      const progress = parseInt(progressInput.value);
      
      let importance = '상';
      const checkedImportance = document.querySelector('input[name="sub-importance"]:checked');
      if (checkedImportance) {
        importance = checkedImportance.value;
      }

      if (!name || !date || isNaN(hours)) {
        showToast("모든 값을 바르게 채워주세요!");
        return;
      }

      const newSubject = {
        id: `subject-${Date.now()}`,
        name,
        examDate: date,
        importance,
        expectedHours: hours,
        progress
      };

      state.subjects.push(newSubject);
      saveState();
      
      closeModal();
      nameInput.value = '';
      dateInput.value = '';
      hoursInput.value = '10';
      progressInput.value = '0';
      document.getElementById('new-progress-val').innerText = '0%';
      document.getElementById('imp-high').checked = true;

      refreshApp();
      showToast(`과목 "${name}"(이)가 등록되었습니다!`);
    }

    function deleteSubject(id) {
      const subject = state.subjects.find(s => s.id === id);
      if (confirm(`과목 "${subject.name}"을(를) 삭제하시겠습니까?`)) {
        state.subjects = state.subjects.filter(s => s.id !== id);
        state.todaySchedule = state.todaySchedule.filter(block => block.subjectId !== id);
        saveState();
        refreshApp();
        showToast("과목이 삭제되었습니다.");
      }
    }

    function updateSubjectProgressDirectly(id, val) {
      const sub = state.subjects.find(s => s.id === id);
      if (sub) {
        sub.progress = parseInt(val);
      }
      renderDashboard();
      const card = document.querySelector(`[onclick="deleteSubject('${id}')"]`).closest('.subject-card');
      card.querySelector('.progress-bar-fill').style.width = `${val}%`;
      card.querySelector('.progress-label span:last-child').innerText = `${val}% (목표 공부시간: ${sub.expectedHours}시간)`;
    }

    function saveStateAndRefresh() {
      saveState();
      renderDashboard();
    }

    // Time conversion helper
    function minutesToTimeString(minutes) {
      const hours = Math.floor(minutes / 60) % 24;
      const mins = minutes % 60;
      const padHours = String(hours).padStart(2, '0');
      const padMins = String(mins).padStart(2, '0');
      return `${padHours}:${padMins}`;
    }

    // Dynamic schedule generation
    function generateAISchedule() {
      const activeSubjects = state.subjects.filter(s => {
        const dDay = calculateDDay(s.examDate);
        return dDay >= 0 && s.progress < 100;
      });

      if (activeSubjects.length === 0) {
        state.todaySchedule = [];
        saveState();
        renderSchedule();
        showToast("진행 예정이거나 공부할 과목이 없습니다.");
        return;
      }

      // 1. Calculate Priority Scores
      const subjectsWithPriority = activeSubjects.map(s => {
        const dDay = calculateDDay(s.examDate);
        
        let dDayScore = 0;
        if (dDay === 0) dDayScore = 100;
        else if (dDay > 0) dDayScore = Math.round(100 * Math.exp(-0.07 * dDay));

        let importanceScore = 30;
        if (s.importance === '상') importanceScore = 100;
        else if (s.importance === '중') importanceScore = 60;

        const hoursScore = Math.min(100, (s.expectedHours / 20) * 100);
        const incompleteScore = 100 - s.progress;

        const priorityScore = (dDayScore * 0.4) + (importanceScore * 0.3) + (hoursScore * 0.2) + (incompleteScore * 0.1);

        return { ...s, priorityScore, dDay };
      });

      subjectsWithPriority.sort((a, b) => b.priorityScore - a.priorityScore);

      // 2. Allocate study time in 30-min increments
      const totalAvailableMins = state.dailyTime * 60;
      const totalPriority = subjectsWithPriority.reduce((sum, s) => sum + s.priorityScore, 0);

      let allocatedMins = [];
      let sumAllocated = 0;

      subjectsWithPriority.forEach((s) => {
        let rawMins = totalAvailableMins * (s.priorityScore / totalPriority);
        let roundedMins = Math.round(rawMins / 30) * 30;
        allocatedMins.push({
          subject: s,
          minutes: roundedMins
        });
        sumAllocated += roundedMins;
      });

      let diff = totalAvailableMins - sumAllocated;
      if (diff !== 0) {
        const steps = Math.abs(diff) / 30;
        const direction = diff > 0 ? 1 : -1;
        for (let i = 0; i < steps; i++) {
          let idx = i % allocatedMins.length;
          allocatedMins[idx].minutes += direction * 30;
          if (allocatedMins[idx].minutes < 0) {
            allocatedMins[idx].minutes = 0;
          }
        }
      }

      const studyTasks = allocatedMins.filter(t => t.minutes > 0);

      if (studyTasks.length === 0) {
        state.todaySchedule = [];
        saveState();
        renderSchedule();
        showToast("공부 시간이 너무 적게 설정되었습니다.");
        return;
      }

      // 3. Sequential Timeline Scheduling Loop
      const schedule = [];
      const startParts = state.startTime.split(':');
      let currentMins = parseInt(startParts[0]) * 60 + parseInt(startParts[1]);

      let lunchScheduled = false;
      let dinnerScheduled = false;

      const LUNCH_START = 12 * 60; // 12:00
      const LUNCH_END = 13 * 60;   // 13:00
      const DINNER_START = 18 * 60; // 18:00
      const DINNER_END = 19 * 60;   // 19:00

      studyTasks.forEach((task, taskIdx) => {
        let remainingMins = task.minutes;
        const subjectName = task.subject.name;
        const subjectId = task.subject.id;

        while (remainingMins > 0) {
          if (state.excludeMeals === 'both' || state.excludeMeals === 'lunch') {
            if (!lunchScheduled && currentMins >= LUNCH_START && currentMins < LUNCH_END) {
              schedule.push({
                id: `lunch-${currentMins}`,
                type: 'meal',
                subject: '점심 식사 시간 🍔',
                startMins: currentMins,
                endMins: LUNCH_END,
                completed: true
              });
              currentMins = LUNCH_END;
              lunchScheduled = true;
              continue;
            }
            if (!lunchScheduled && currentMins < LUNCH_START && currentMins + Math.min(50, remainingMins) > LUNCH_START) {
              let studyDuration = LUNCH_START - currentMins;
              schedule.push({
                id: `study-${subjectId}-${currentMins}`,
                subjectId: subjectId,
                type: 'study',
                subject: subjectName,
                startMins: currentMins,
                endMins: LUNCH_START,
                completed: false
              });
              currentMins = LUNCH_START;
              remainingMins -= studyDuration;
              continue;
            }
          }

          if (state.excludeMeals === 'both' || state.excludeMeals === 'dinner') {
            if (!dinnerScheduled && currentMins >= DINNER_START && currentMins < DINNER_END) {
              schedule.push({
                id: `dinner-${currentMins}`,
                type: 'meal',
                subject: '저녁 식사 시간 🍕',
                startMins: currentMins,
                endMins: DINNER_END,
                completed: true
              });
              currentMins = DINNER_END;
              dinnerScheduled = true;
              continue;
            }
            if (!dinnerScheduled && currentMins < DINNER_START && currentMins + Math.min(50, remainingMins) > DINNER_START) {
              let studyDuration = DINNER_START - currentMins;
              schedule.push({
                id: `study-${subjectId}-${currentMins}`,
                subjectId: subjectId,
                type: 'study',
                subject: subjectName,
                startMins: currentMins,
                endMins: DINNER_START,
                completed: false
              });
              currentMins = DINNER_START;
              remainingMins -= studyDuration;
              continue;
            }
          }

          let blockDuration = state.includeBreaks ? Math.min(50, remainingMins) : remainingMins;
          schedule.push({
            id: `study-${subjectId}-${currentMins}`,
            subjectId: subjectId,
            type: 'study',
            subject: subjectName,
            startMins: currentMins,
            endMins: currentMins + blockDuration,
            completed: false
          });
          currentMins += blockDuration;
          remainingMins -= blockDuration;

          if (state.includeBreaks && remainingMins > 0) {
            let breakDuration = 10;
            if (state.excludeMeals === 'both' || state.excludeMeals === 'lunch') {
              if (!lunchScheduled && currentMins < LUNCH_START && currentMins + 10 > LUNCH_START) {
                breakDuration = LUNCH_START - currentMins;
              }
            }
            if (state.excludeMeals === 'both' || state.excludeMeals === 'dinner') {
              if (!dinnerScheduled && currentMins < DINNER_START && currentMins + 10 > DINNER_START) {
                breakDuration = DINNER_START - currentMins;
              }
            }
            
            if (breakDuration > 0) {
              schedule.push({
                id: `break-${currentMins}`,
                type: 'break',
                subject: '쉬는 시간 ☕',
                startMins: currentMins,
                endMins: currentMins + breakDuration,
                completed: true
              });
              currentMins += breakDuration;
            }
          }
        }

        if (state.includeBreaks && taskIdx < studyTasks.length - 1) {
          let nextMealComing = false;
          if (state.excludeMeals === 'both' || state.excludeMeals === 'lunch') {
            if (!lunchScheduled && currentMins === LUNCH_START) nextMealComing = true;
          }
          if (state.excludeMeals === 'both' || state.excludeMeals === 'dinner') {
            if (!dinnerScheduled && currentMins === DINNER_START) nextMealComing = true;
          }
          
          if (!nextMealComing) {
            schedule.push({
              id: `break-transition-${currentMins}`,
              type: 'break',
              subject: '과목 전환 휴식 🏃',
              startMins: currentMins,
              endMins: currentMins + 10,
              completed: true
            });
            currentMins += 10;
          }
        }
      });

      state.todaySchedule = schedule;
      saveState();
      renderSchedule();
      showToast("새로운 AI 맞춤 공부 계획이 생성되었습니다!");
    }

    // Render Timeline schedule
    function renderSchedule() {
      const container = document.getElementById('schedule-container');
      const percentageText = document.getElementById('schedule-percentage-text');
      
      if (!state.todaySchedule || state.todaySchedule.length === 0) {
        container.innerHTML = `
          <div class="empty-state">
            오늘 생성된 스케줄이 없습니다. 위의 설정을 맞추고 "AI 맞춤 공부 계획 생성" 버튼을 눌러주세요.
          </div>
        `;
        percentageText.innerText = "완료율 0%";
        return;
      }

      const studyBlocks = state.todaySchedule.filter(b => b.type === 'study');
      const completedBlocks = studyBlocks.filter(b => b.completed);
      const completionPercent = studyBlocks.length > 0 ? Math.round((completedBlocks.length / studyBlocks.length) * 100) : 0;
      
      percentageText.innerText = `완료율 ${completionPercent}% (${completedBlocks.length}/${studyBlocks.length} 완료)`;

      let timelineHTML = '<div class="timeline">';
      
      state.todaySchedule.forEach(block => {
        const timeStr = `${minutesToTimeString(block.startMins)} ~ ${minutesToTimeString(block.endMins)}`;
        const cardClass = block.completed ? 'timeline-card completed' : 'timeline-card';
        const itemClass = `timeline-item ${block.type} ${block.completed ? 'completed' : ''}`;
        
        let typeBadgeHTML = '';
        if (block.type === 'study') {
          typeBadgeHTML = `<span class="timeline-type-badge timeline-type-study">공부</span>`;
        } else if (block.type === 'break') {
          typeBadgeHTML = `<span class="timeline-type-badge timeline-type-break">휴식</span>`;
        } else if (block.type === 'meal') {
          typeBadgeHTML = `<span class="timeline-type-badge timeline-type-meal">식사</span>`;
        }

        let actionHTML = '';
        if (block.type === 'study') {
          actionHTML = `
            <button class="schedule-check-btn ${block.completed ? 'checked' : ''}" 
              onclick="toggleScheduleBlock('${block.id}')" aria-label="완료 체크">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </button>
          `;
        } else {
          actionHTML = `
            <span style="color: var(--accent-green); display: flex; align-items: center;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </span>
          `;
        }

        timelineHTML += `
          <div class="${itemClass}">
            <div class="${cardClass}">
              <div class="timeline-info">
                <span class="timeline-time">${timeStr}</span>
                <span class="timeline-subject">
                  ${block.subject}
                  ${typeBadgeHTML}
                </span>
              </div>
              <div>
                ${actionHTML}
              </div>
            </div>
          </div>
        `;
      });

      timelineHTML += '</div>';
      container.innerHTML = timelineHTML;
    }

    // Toggle Study Block Checklist item
    function toggleScheduleBlock(id) {
      const block = state.todaySchedule.find(b => b.id === id);
      if (!block || block.type !== 'study') return;

      block.completed = !block.completed;

      const subject = state.subjects.find(s => s.id === block.subjectId);
      if (subject) {
        const blockDurationHours = (block.endMins - block.startMins) / 60;
        const deltaProgress = (blockDurationHours / subject.expectedHours) * 100;
        
        if (block.completed) {
          subject.progress = Math.min(100, Math.round(subject.progress + deltaProgress));
        } else {
          subject.progress = Math.max(0, Math.round(subject.progress - deltaProgress));
        }
      }

      saveState();
      renderSchedule();
      renderSubjects();
      renderDashboard();

      const studyBlocks = state.todaySchedule.filter(b => b.type === 'study');
      const allDone = studyBlocks.every(b => b.completed);
      
      if (allDone && block.completed) {
        triggerConfettiEffect();
        showToast("축하합니다! 오늘의 공부 계획을 모두 완료하셨습니다! 🎉");
      } else if (block.completed) {
        showToast(`"${block.subject}" 공부 완료! 수고하셨습니다.`);
      }
    }

    function triggerConfettiEffect() {
      confetti({
        particleCount: 100,
        spread: 70,
        origin: { y: 0.6 }
      });
      setTimeout(() => {
        confetti({
          particleCount: 50,
          angle: 60,
          spread: 55,
          origin: { x: 0 }
        });
        confetti({
          particleCount: 50,
          angle: 120,
          spread: 55,
          origin: { x: 1 }
        });
      }, 250);
    }

    const modal = document.getElementById('add-modal');
    
    function openModal() {
      modal.classList.add('open');
      const tomorrow = new Date();
      tomorrow.setDate(tomorrow.getDate() + 1);
      document.getElementById('sub-date').value = tomorrow.toISOString().split('T')[0];
    }

    function closeModal() {
      modal.classList.remove('open');
    }

    document.getElementById('open-add-modal-btn').addEventListener('click', openModal);
    document.getElementById('close-add-modal-btn').addEventListener('click', closeModal);
    document.getElementById('cancel-add-btn').addEventListener('click', closeModal);
    
    document.getElementById('add-subject-form').addEventListener('submit', addSubject);

    const timeInput = document.getElementById('daily-study-time-input');
    timeInput.addEventListener('input', (e) => {
      document.getElementById('study-time-val').innerText = `${e.target.value}시간`;
      state.dailyTime = parseInt(e.target.value);
      saveState();
    });

    document.getElementById('start-time-input').addEventListener('change', (e) => {
      state.startTime = e.target.value;
      saveState();
    });

    document.getElementById('meal-exclusion-select').addEventListener('change', (e) => {
      state.excludeMeals = e.target.value;
      saveState();
    });

    document.getElementById('break-toggle-input').addEventListener('change', (e) => {
      state.includeBreaks = e.target.checked;
      saveState();
    });

    document.getElementById('generate-plan-btn').addEventListener('click', generateAISchedule);

    document.getElementById('sub-progress').addEventListener('input', (e) => {
      document.getElementById('new-progress-val').innerText = `${e.target.value}%`;
    });

    document.getElementById('theme-toggle').addEventListener('click', () => {
      const currentTheme = document.documentElement.getAttribute('data-theme');
      const newTheme = currentTheme === 'light' ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', newTheme);
      state.theme = newTheme;
      saveState();
      updateThemeToggleUI();
    });

    function refreshApp() {
      renderDashboard();
      renderSubjects();
      renderSchedule();
    }

    window.addEventListener('DOMContentLoaded', () => {
      const today = new Date();
      const options = { year: 'numeric', month: '2-digit', day: '2-digit', weekday: 'short' };
      document.getElementById('header-date').innerText = today.toLocaleDateString('ko-KR', options);

      loadState();
      refreshApp();
    });
  </script>
</body>
